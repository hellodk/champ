{
  "name": "aidev",
  "displayName": "AIDev - AI Coding Agent",
  "description": "Cursor-like AI coding experience with local LLM support, multi-agent orchestration, and autonomous workflows",
  "version": "0.1.1",
  "publisher": "aidev-oss",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "llm",
    "claude",
    "ollama",
    "local-llm",
    "coding-agent",
    "autocomplete",
    "multi-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aidev-oss/aidev"
  },
  "bugs": {
    "url": "https://github.com/aidev-oss/aidev/issues"
  },
  "homepage": "https://github.com/aidev-oss/aidev#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aidev-sidebar",
          "title": "AIDev",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "aidev-sidebar": [
        {
          "type": "webview",
          "id": "aidev.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "aidev.newChat",
        "title": "AIDev: New Chat"
      },
      {
        "command": "aidev.toggleMode",
        "title": "AIDev: Toggle Mode"
      },
      {
        "command": "aidev.indexWorkspace",
        "title": "AIDev: Index Workspace"
      },
      {
        "command": "aidev.restoreCheckpoint",
        "title": "AIDev: Restore Checkpoint"
      },
      {
        "command": "aidev.openSettings",
        "title": "AIDev: Settings"
      },
      {
        "command": "aidev.setApiKey",
        "title": "AIDev: Set API Key"
      }
    ],
    "configuration": {
      "title": "AIDev",
      "properties": {
        "aidev.provider": {
          "type": "string",
          "default": "claude",
          "enum": [
            "claude",
            "openai",
            "gemini",
            "ollama",
            "llamacpp",
            "vllm",
            "openai-compatible"
          ],
          "description": "Active LLM provider"
        },
        "aidev.claude.apiKey": {
          "type": "string",
          "description": "Anthropic API key"
        },
        "aidev.claude.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514"
        },
        "aidev.openai.apiKey": {
          "type": "string",
          "description": "OpenAI API key"
        },
        "aidev.openai.model": {
          "type": "string",
          "default": "gpt-4o"
        },
        "aidev.gemini.apiKey": {
          "type": "string",
          "description": "Google Gemini API key"
        },
        "aidev.gemini.model": {
          "type": "string",
          "default": "gemini-2.0-flash"
        },
        "aidev.ollama.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434"
        },
        "aidev.ollama.model": {
          "type": "string",
          "default": "llama3.1"
        },
        "aidev.llamacpp.baseUrl": {
          "type": "string",
          "default": "http://localhost:8080"
        },
        "aidev.llamacpp.model": {
          "type": "string",
          "default": "default"
        },
        "aidev.vllm.baseUrl": {
          "type": "string",
          "default": "http://localhost:8000"
        },
        "aidev.vllm.model": {
          "type": "string"
        },
        "aidev.openaiCompatible.baseUrl": {
          "type": "string"
        },
        "aidev.openaiCompatible.model": {
          "type": "string"
        },
        "aidev.openaiCompatible.apiKey": {
          "type": "string"
        },
        "aidev.yoloMode": {
          "type": "boolean",
          "default": false,
          "description": "Skip approval for terminal commands and file edits"
        },
        "aidev.autoFix.enabled": {
          "type": "boolean",
          "default": true
        },
        "aidev.autoFix.maxIterations": {
          "type": "number",
          "default": 3
        },
        "aidev.indexing.enabled": {
          "type": "boolean",
          "default": true
        },
        "aidev.indexing.embeddingProvider": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "ollama",
            "openai"
          ]
        },
        "aidev.autocomplete.enabled": {
          "type": "boolean",
          "default": true
        },
        "aidev.autocomplete.debounceMs": {
          "type": "number",
          "default": 300
        },
        "aidev.autocomplete.model": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b"
        },
        "aidev.userRules": {
          "type": "string",
          "default": "",
          "description": "Global rules applied to all projects"
        },
        "aidev.mcp.servers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object"
              }
            }
          },
          "description": "MCP server configurations"
        }
      }
    },
    "keybindings": [
      {
        "command": "aidev.newChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "aidev.toggleMode",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ]
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.mjs",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.mjs --watch",
    "watch:types": "tsc --noEmit --watch",
    "check-types": "tsc --noEmit",
    "package": "npm run check-types && node esbuild.mjs --production",
    "vscode:prepublish": "npm run package",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vscode-test",
    "test:report": "node scripts/run-tests-and-report.js",
    "lint": "eslint src/ test/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'webview-ui/src/**/*.tsx'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "npm-run-all": "^4.1.5",
    "openai": "^4.77.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "tiktoken": "^1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
