{
  "name": "champ",
  "displayName": "Champ - AI Coding Agent",
  "description": "AI coding agent with local LLM support, multi-agent orchestration, and autonomous workflows",
  "version": "1.6.0",
  "publisher": "champ-oss",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "llm",
    "claude",
    "ollama",
    "local-llm",
    "coding-agent",
    "autocomplete",
    "multi-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hellodk/champ"
  },
  "bugs": {
    "url": "https://github.com/hellodk/champ/issues"
  },
  "homepage": "https://github.com/hellodk/champ#readme",
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:champ.default"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "champ.default",
        "name": "champ",
        "fullName": "Champ",
        "description": "AI coding agent with local LLM support",
        "isSticky": true,
        "commands": []
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "champ-sidebar",
          "title": "Champ",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "champ-sidebar": [
        {
          "type": "webview",
          "id": "champ.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "champ.newChat",
        "title": "Champ: New Chat"
      },
      {
        "command": "champ.toggleMode",
        "title": "Champ: Toggle Mode"
      },
      {
        "command": "champ.indexWorkspace",
        "title": "Champ: Index Workspace"
      },
      {
        "command": "champ.restoreCheckpoint",
        "title": "Champ: Restore Checkpoint"
      },
      {
        "command": "champ.openSettings",
        "title": "Champ: Settings"
      },
      {
        "command": "champ.setApiKey",
        "title": "Champ: Set API Key"
      },
      {
        "command": "champ.generateConfig",
        "title": "Champ: Generate Config File"
      },
      {
        "command": "champ.showHelp",
        "title": "Champ: Show User Guide"
      },
      {
        "command": "champ.setActiveModel",
        "title": "Champ: Set Active Model"
      },
      {
        "command": "champ.showOnboarding",
        "title": "Champ: Show Onboarding"
      },
      {
        "command": "champ.cleanupSessions",
        "title": "Champ: Clean Up Old Sessions"
      },
      {
        "command": "champ.runMultiAgent",
        "title": "Champ: Run Multi-Agent Workflow"
      },
      {
        "command": "champ.showAnalytics",
        "title": "Champ: Show Analytics"
      }
    ],
    "configuration": {
      "title": "Champ",
      "properties": {
        "champ.provider": {
          "type": "string",
          "default": "claude",
          "enum": [
            "claude",
            "openai",
            "gemini",
            "ollama",
            "llamacpp",
            "vllm",
            "openai-compatible"
          ],
          "markdownDescription": "Active LLM provider. Edit **`.champ/config.yaml`** for full control (YAML overrides these settings)."
        },
        "champ.claude.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "markdownDescription": "Claude model ID. API key is stored securely — run **Champ: Set API Key** to configure it."
        },
        "champ.openai.model": {
          "type": "string",
          "default": "gpt-4o",
          "markdownDescription": "OpenAI model ID. API key is stored securely — run **Champ: Set API Key** to configure it."
        },
        "champ.gemini.model": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "markdownDescription": "Gemini model ID. API key is stored securely — run **Champ: Set API Key** to configure it."
        },
        "champ.ollama.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "markdownDescription": "Ollama server base URL. Default is local; set to a remote address if Ollama runs on another machine."
        },
        "champ.ollama.model": {
          "type": "string",
          "default": "qwen2.5-coder:7b-instruct",
          "markdownDescription": "Ollama model tag. Must match an installed model — run `ollama pull <model>` to install."
        },
        "champ.llamacpp.baseUrl": {
          "type": "string",
          "default": "http://localhost:8080/v1",
          "markdownDescription": "llama.cpp server base URL **including `/v1`** (e.g. `http://localhost:8080/v1`)."
        },
        "champ.llamacpp.model": {
          "type": "string",
          "default": "default"
        },
        "champ.vllm.baseUrl": {
          "type": "string",
          "default": "http://localhost:8000/v1",
          "markdownDescription": "vLLM server base URL **including `/v1`** (e.g. `http://localhost:8000/v1`)."
        },
        "champ.vllm.model": {
          "type": "string",
          "markdownDescription": "vLLM model ID (e.g. `meta-llama/Llama-3.1-8B`)."
        },
        "champ.vllm.apiKey": {
          "type": "string",
          "markdownDescription": "vLLM API key (if your server requires authentication). Store securely via **Champ: Set API Key** command."
        },
        "champ.openaiCompatible.baseUrl": {
          "type": "string",
          "markdownDescription": "Base URL for an OpenAI-compatible server **including `/v1`**."
        },
        "champ.openaiCompatible.model": {
          "type": "string"
        },
        "champ.openaiCompatible.apiKey": {
          "type": "string",
          "markdownDescription": "API key for the OpenAI-compatible server. Store securely via **Champ: Set API Key** command."
        },
        "champ.yoloMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Skip approval prompts for terminal commands and file edits. **Use with caution.**"
        },
        "champ.autoFix.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Re-prompt the model with LSP errors after edits to auto-fix issues."
        },
        "champ.autoFix.maxIterations": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "Maximum auto-fix iterations per edit cycle."
        },
        "champ.indexing.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable codebase indexing for @Codebase semantic search."
        },
        "champ.indexing.embeddingProvider": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "ollama",
            "openai"
          ],
          "markdownDescription": "Provider for codebase embedding (semantic search). Only `ollama` and `openai` support embeddings."
        },
        "champ.autocomplete.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline ghost-text autocomplete."
        },
        "champ.autocomplete.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay (ms) before triggering a completion request."
        },
        "champ.autocomplete.model": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b",
          "description": "Model to use for inline autocomplete (can be a smaller/faster model than chat)."
        },
        "champ.userRules": {
          "type": "string",
          "default": "",
          "description": "Global rules always injected into the agent system prompt."
        },
        "champ.mcp.servers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object"
              }
            }
          },
          "markdownDescription": "MCP server configurations. Each server extends the agent with external tools."
        }
      }
    },
    "keybindings": [
      {
        "command": "champ.newChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "champ.toggleMode",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ]
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.mjs",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.mjs --watch",
    "watch:types": "tsc --noEmit --watch",
    "check-types": "tsc --noEmit",
    "package": "npm run check-types && node esbuild.mjs --production",
    "vscode:prepublish": "npm run package",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vscode-test",
    "test:report": "node scripts/run-tests-and-report.js",
    "lint": "eslint src/ test/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'webview-ui/src/**/*.tsx'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "npm-run-all": "^4.1.5",
    "openai": "^4.77.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "js-yaml": "^4.1.1",
    "tiktoken": "^1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
